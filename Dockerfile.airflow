FROM apache/airflow:2.7.0-python3.10

USER root

RUN apt-get update && apt-get install -y \
    build-essential \
    python3-dev \
    libpq-dev \
    gcc \
    curl \
    wget \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# on repasse sur airflow user POUR pip
USER airflow

# install des dep python
RUN pip install --no-cache-dir scrapy scrapy-playwright psycopg2-binary blis==0.7.9

# playwright install doit être après pip
RUN playwright install firefox

WORKDIR /opt/airflow
